{
  "$schema": "https://opencode.ai/config.json",
  "model": "skainet/zai-org/GLM-5.1-FP8",
  "autoupdate": true,
  "default_agent": "office-coworker",
  "permission": {
    "bash": {
      "*": "allow",
      "find *": "deny",
      "grep *": "deny",
      "rg *": "deny",
      "cat *": "deny",
      "head *": "deny",
      "tail *": "deny",
      "sed *": "deny",
      "awk *": "deny",
      "echo *": "deny",
      "ls *": "deny"
    }
  },
  "provider": {
    "someProvider": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://some.url.com/v1"
      },
      "models": {
        "some-creator/some-model": {}
      }
    },
    "skainet": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://chat.model.tngtech.com/v1"
      },
      "models": {
        "zai-org/GLM-5.1-FP8": {},
        "zai-org/GLM-4.7-Flash": {},
        "tngtech/olmocr-7B-faithful": {},
        "allenai/olmOCR-2-7B-1025-FP8": {},
        "openai/gpt-oss-120b": {},
        "Qwen/Qwen3Guard-Gen-8B": {},
        "tngtech/tng-codepilot-v2": {},
        "tngtech/DeepSeek-TNG-R1T2-Chimera-guarded": {},
        "mistralai/Mistral-Small-3.2-24B-Instruct-2506": {},
        "Qwen/Qwen3.5-397B-A17B-FP8": {},
        "Qwen/Qwen3.5-35B-A3B-FP8": {},
        "tngtech/tng-codepilot": {},
        "tngtech/DeepSeek-TNG-R1T2-Chimera": {},
        "zai-org/GLM-4.7-FP8": {}
      }
    }
  }
}
